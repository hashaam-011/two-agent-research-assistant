# ---------------------------------------------------------------------------
# Required env vars for the frontend. Copy this file to `.env.local` and fill
# in real values. `.env.local` is gitignored.
#
# Every variable below MUST be set. The frontend fails fast on startup if any
# of them are missing.
# ---------------------------------------------------------------------------

# REQUIRED — where the browser POSTs the planner request.
#
# Pick one:
#   /api/agent          — same-origin proxy (recommended; pairs with PLANNER_URL)
#   /api/mock-planner   — drive the UI from the local mock, no backend running
#   http://…/agent      — absolute URL, only if upstream allows CORS
NEXT_PUBLIC_AGENT_URL=/api/agent

# REQUIRED (only if NEXT_PUBLIC_AGENT_URL=/api/agent) — where the proxy forwards
# the request. Server-side only; never reaches the browser.
PLANNER_URL=http://localhost:8000/agent
